{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EnvWeave",
  "version": "0.1.0-alpha.1",
  "identifier": "io.envweave.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EnvWeave",
        "width": 1120,
        "height": 760,
        "minWidth": 820,
        "minHeight": 560,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; worker-src 'self' blob:; img-src 'self' data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "copyright": "Copyright © 2026 EnvWeave contributors",
    "shortDescription": "Linux 与 macOS 环境迁移管理器",
    "longDescription": "收集、比较、版本管理并安全恢复配置文件与软件清单。",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "bundleVersion": "1"
    }
  }
}
